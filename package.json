{
  "name": "bolao-copa-api",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "strapi build",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v",
    "dev:docker": "yarn db:up && yarn dev",
    "generate:wc2026": "node scripts/generate-wc2026-data.mjs",
    "seed:wc2026": "tsx ./src/scripts/seed-wc2026.ts",
    "seed:wc2026:flags": "tsx ./src/scripts/seed-wc2026.ts --flags",
    "simulate:wc2026:groups": "tsx ./src/scripts/simulate-wc2026-group-stage.ts",
    "sync:scores": "strapi build && node dist/src/scripts/sync-scores.js",
    "dev": "strapi develop",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "test": "tsx --test src/api/bet/services/scoring.test.ts src/api/bet/services/bet-guards.test.ts src/api/bet/services/recalculate-match-points.test.ts src/api/user-ranking/services/compute-user-ranking.test.ts src/api/bet/controllers/bet.test.ts src/auth/users-permissions-auth.test.ts src/integrations/match-status-sync-rules.test.ts src/integrations/football-data.test.ts src/integrations/worldcup26.test.ts",
    "start": "strapi start",
    "strapi": "strapi"
  },
  "dependencies": {
    "@strapi/plugin-cloud": "5.45.0",
    "@strapi/plugin-users-permissions": "5.45.0",
    "@strapi/provider-email-nodemailer": "5.45.0",
    "@strapi/strapi": "5.45.0",
    "pg": "^8.20.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "sharp": "0.33.5",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2"
  },
  "resolutions": {
    "sharp": "0.33.5"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "yarn": ">=1.22.0"
  },
  "strapi": {
    "uuid": "97655d26-d0b6-40ae-8336-f77bc344750e",
    "installId": "ec458e5458b70862aff000790a493460155109d85496d87e7648c4004f08c9f8"
  }
}
