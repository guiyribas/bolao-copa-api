# Server
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337

# Secrets (generate unique values per environment; never commit real production secrets)
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Frontend
FRONTEND_URL=http://localhost:3000

# Transactional email (password reset)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM="Bolao Copa <no-reply@example.com>"
# EMAIL_REPLY_TO=support@example.com

# Production-only: seed fixtures, flags, and Users & Permissions on startup.
# Leave unset locally so your populated Postgres is untouched.
# AUTO_BOOTSTRAP_PRODUCTION=true

# WC2026 seleções + jogos: rode manualmente na raiz quando quiser (PostgreSQL no ar):
# yarn seed:wc2026
# Bandeiras opcional (rede): yarn seed:wc2026:flags  ou  yarn seed:wc2026 -- --flags --flags-force

# Database (local dev — keep production connection strings out of this file)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=bolao_copa
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false
# DATABASE_POOL_MIN=0
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Score synchronization. Providers: football-data | worldcup26
# SCORE_PROVIDER=football-data
# SCORE_SYNC_ENABLED=false

# football-data.org (FIFA World Cup: competition WC, season 2026)
# FOOTBALL_DATA_API_KEY=
# FOOTBALL_DATA_API_URL=https://api.football-data.org/v4
# FOOTBALL_DATA_COMPETITION=WC
# FOOTBALL_DATA_SEASON=2026
# FOOTBALL_DATA_TIMEOUT_MS=15000
# FOOTBALL_DATA_CRON=

# worldcup26 open-source API (no API key)
# WORLDCUP26_API_URL=https://worldcup26.ir
# WORLDCUP26_TIMEOUT_MS=15000
# WORLDCUP26_CRON=
