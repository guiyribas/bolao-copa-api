{
  "kind": "collectionType",
  "collectionName": "pools",
  "info": {
    "singularName": "pool",
    "pluralName": "pools",
    "displayName": "Pool",
    "description": "Bolões criados pelos usuários"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "value": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "inviteCode": {
      "type": "string",
      "unique": true
    },
    "admin": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "memberships": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::pool-membership.pool-membership",
      "mappedBy": "pool"
    }
  }
}
